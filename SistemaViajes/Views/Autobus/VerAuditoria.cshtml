@model IEnumerable<SistemaViajes.Models.AuditoriaReserva>

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-clipboard-data"></i> Bitácora de Mantenimientos y Auditoría</h4>
            <a asp-action="Index" class="btn btn-outline-light btn-sm">Volver</a>
        </div>
        <div class="card-body bg-light">
            <form method="get" class="row g-3 mb-4 p-3 bg-white rounded shadow-sm">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-secondary">Mes</label>
                    <select name="mes" class="form-select">
                        <option value="">-- Todos los meses --</option>
                        @foreach (var m in ViewBag.Meses)
                        {
                            <option value="@m.Id">@m.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-secondary">Tipo de Reparación</label>
                    <input type="text" name="tipo" class="form-control" placeholder="Ej: Frenos, Aceite..." />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filtrar Auditoría
                    </button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha/Hora</th>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Detalle del Cambio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FechaAccion.ToString("g")</td>
                                <td><span class="badge bg-info text-dark">@item.Usuario</span></td>
                                <td><strong>@item.Accion</strong></td>
                                <td class="text-muted" style="font-size: 0.9rem;">@item.DetalleAdicional</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>