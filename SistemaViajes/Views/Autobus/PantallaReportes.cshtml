@model IEnumerable<SistemaViajes.Models.ReporteMantenimientoVM>

<div class="container mt-4">
    <div class="card border-primary shadow">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-graph-up"></i> Reporte Especial de Mantenimientos</h4>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 mb-4 border-bottom pb-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Mes del Año</label>
                    <select name="filtroMes" class="form-select">
                        <option value="">-- Seleccionar Mes --</option>
                        <option value="1">Enero</option>
                        <option value="4">Abril</option>
                        @* Agregá los demás meses *@
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Tipo de Reparación</label>
                    <input type="text" name="filtroTipo" class="form-control" placeholder="Ej: Frenos" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark w-100">Generar Reporte</button>
                </div>
            </form>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Mes</th>
                        <th>Técnico/Usuario</th>
                        <th>Tipo Reparación</th>
                        <th>Descripción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToShortDateString()</td>
                            <td><span class="badge bg-secondary">@item.NombreMes</span></td>
                            <td>@item.Usuario</td>
                            <td><span class="text-primary fw-bold">@item.TipoReparacion</span></td>
                            <td>@item.Detalle</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>