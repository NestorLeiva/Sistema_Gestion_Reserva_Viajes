@model IEnumerable<SistemaViajes.Models.Empleado>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people-fill"></i> Gestión de Empleados</h2>
        <a asp-action="Crear" class="btn btn-success shadow-sm"><i class="bi bi-plus-circle"></i> Nuevo Empleado</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Cédula</th>
                        <th>Nombre Completo</th>
                        <th>Rol / Puesto</th>
                        <th>Usuario Sistema</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@item.Cedula</td>
                            <td>@item.NombreCompleto</td>
                            <td><span class="badge bg-info text-dark">@item.RolNavigation?.NombreRol</span></td>
                            <td>
                                @if (item.UsuarioSistemas != null && item.UsuarioSistemas.Any())
                                {
                                    <span class="text-primary fw-bold">
                                        <i class="bi bi-person-badge"></i> @item.UsuarioSistemas.FirstOrDefault()?.NombreUsuario
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small"><em>Sin cuenta</em></span>
                                }
                            </td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i> Activo</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Inactivo</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a asp-action="Editar" asp-route-id="@item.PkIdEmpleado" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Eliminar" asp-route-id="@item.PkIdEmpleado" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>