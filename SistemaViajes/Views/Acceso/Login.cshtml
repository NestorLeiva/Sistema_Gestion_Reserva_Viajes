@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Sistema Viajes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card p-4 shadow border-0">
                    <div class="text-center mb-3">
                        <i class="bi bi-bus-front text-primary" style="font-size: 3rem;"></i>
                        <h3 class="mt-2">Sistema Viajes</h3>
                        <p class="text-muted">Ingrese sus credenciales</p>
                    </div>

                    <hr />

                    <form asp-controller="Acceso" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Usuario:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" name="usuario" class="form-control" placeholder="Nombre de usuario" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" name="clave" class="form-control" placeholder="********" required />
                            </div>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger d-flex align-items-center" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <div>@ViewBag.Error</div>
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100 shadow-sm py-2">
                            <i class="bi bi-box-arrow-in-right"></i> Entrar al Sistema
                        </button>
                    </form>
                </div>
                <div class="text-center mt-4">
                    <small class="text-muted">&copy; 2026 Colegio Universitario de Cartago</small>
                </div>
            </div>
        </div>
    </div>
</body>
</html>