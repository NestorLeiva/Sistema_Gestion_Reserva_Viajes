@model IEnumerable<SistemaViajes.Models.Viaje>

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-calendar-event"></i> Próximos Viajes</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Ruta</th>
                        <th>Fecha y Hora</th>
                        <th>Precio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td><strong>@v.Origen</strong> <i class="bi bi-arrow-right"></i> <strong>@v.Destino</strong></td>
                            <td>@v.FechaSalida.ToString("dd/MM/yyyy hh:mm tt")</td>
                            <td><span class="text-success fw-bold">₡@v.Precio.ToString("N2")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>