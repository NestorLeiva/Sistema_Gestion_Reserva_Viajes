@model IEnumerable<SistemaViajes.Models.Cliente>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Listado de Clientes</h2>
        <a asp-action="Crear" class="btn btn-success">+ Nuevo Cliente</a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Cédula</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Correo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Cedula</td>
                    <td>@item.NombreCompleto</td>
                    <td>@item.Telefono</td>
                    <td>@item.Correo</td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@item.PkIdCliente"
                           class="btn btn-warning btn-sm">
                            Modificar
                        </a>

                        <a asp-action="Eliminar" asp-route-id="@item.PkIdCliente"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('¿Seguro que quiere borrar este cliente?')">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>