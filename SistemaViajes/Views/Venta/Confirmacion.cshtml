@model SistemaViajes.Models.Factura

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h2 class="text-success fw-bold">PAGO EXITOSO</h2>
                        <p class="text-muted">Factura No: @Model.NumeroFactura</p>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Cliente:</span>
                        <span class="fw-bold">@Model.FkReservacionNavigation.FkClienteNavigation.NombreCompleto</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Ruta:</span>
                        <span class="fw-bold">@Model.FkReservacionNavigation.FkViajeNavigation.FkRutaNavigation.NombreRuta</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Asientos:</span>
                        <span class="fw-bold">@Model.FkReservacionNavigation.CantidadAsientos</span>
                    </div>

                    <hr class="my-4" style="border-top: 2px dashed #ccc;">

                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <span>₡@Model.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>IVA (13%):</span>
                        <span>₡@Model.Impuestos.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mt-3">
                        <span class="h4">TOTAL:</span>
                        <span class="h4 text-success fw-bold">₡@Model.MontoTotal.ToString("N2")</span>
                    </div>

                    <div class="mt-4 no-print">
                        <button onclick="window.print()" class="btn btn-dark w-100 mb-2">Imprimir</button>
                        <a href="@Url.Action("Index", "Viaje")" class="btn btn-primary w-100">
                            <i class="bi bi-house-door"></i> Finalizar y Volver al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none;
        }
    }
</style>